---
const { variant } = Astro.props;
---

<style>
    button {
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: medium;
        cursor: pointer;
        margin-inline-end: 0.4rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: "Inter", sans;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }
    button::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        transition: left 0.5s;
    }
    button:hover::before {
        left: 100%;
    }
    button:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
    }
    button:active {
        transform: translateY(0);
        animation: buttonClick 0.4s ease;
    }

    @keyframes buttonClick {
        0% { box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3), inset 0 0 0 0 rgba(255, 255, 255, 0.3); }
        100% { box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3), inset 0 0 0 10px rgba(255, 255, 255, 0); }
    }
    .primary {
        background: linear-gradient(135deg, var(--primary), #3e63dd);
        color: white;
    }
    .primary:hover {
        background: linear-gradient(135deg, #3e63dd, var(--primary));
    }

    /* @media (max-width: 768px) {
        button {
            padding: 0.6rem 1rem;
            font-size: small;
        }
    } */
</style>

<button class:list={[{ primary: variant === "primary" }]}>
    <slot />
</button>
