---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  image?: string;
  links?: { text: string; href: string }[];
  class?: string;
}
const { title, subtitle, description, links = [], image, class: className = '' } = Astro.props;
---

<div class={`wrapper ${className}`}>
  <div class="container">
    <div class="header">
      {
        image
          ? <img src={image} alt={title} />
          : <div class="default-icon">💼</div>
      }
      <div class="title">
        <h3>{title}</h3>
        <p>{subtitle}</p>
      </div>
    </div>

    <div class="details">
      <p set:html={description}></p>
    </div>

    {links.length > 0 && (
      <div class="footer">
        {links.map((link) => (
          <a href={link.href} target="_blank">{link.text}</a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .wrapper {
    border-left: solid 1px rgba(255, 255, 255, 0.2);
    position: relative;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .wrapper.animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
  }

  .wrapper.animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .wrapper::before {
    content: "";
    position: absolute;
    left: 0;
    top: 16px;
    width: 10px;
    height: 10px;
    background-color: var(--color);
    border-radius: 50%;
    transform: translateX(-50%);
    animation: ringPulse 2s infinite;
  }

  @keyframes ringPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(var(--accent), 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(var(--accent), 0); }
  }

  .container {
    padding: 1rem 2rem;
    border-radius: 0.8rem;
    max-width: 90%;
    margin-inline-start: 1.6rem;
    color: var(--color);
    padding-bottom: 40px;
    transition: all 0.4s ease;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .container:hover {
    transform: translateX(10px) translateY(-6px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(var(--accent), 0.1);
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(var(--accent), 0.3);
  }

  .header {
    display: flex;
    align-items: center;
    margin-bottom: 0.6rem;
  }

  .header img {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .default-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    color: white;
  }

  .header .title {
    margin-inline-start: 0.8rem;
  }

  .header .title h3 {
    margin: 0;
    font-size: 1.15rem;
    color: var(--color);
    font-weight: 600;
  }

  .header .title p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-light);
  }

  .details p {
    font-size: 1rem;
    margin: 0.5rem 0;
    color: var(--text-light);
    line-height: 1.6;
  }

  .details p strong {
    color: white;
    font-weight: 600;
  }

  .footer {
    margin-top: 0.5rem;
  }

  .footer a {
    color: var(--primary);
    text-decoration: none;
    margin-right: 1rem;
    font-size: 0.85rem;
  }

  .footer a:hover {
    opacity: 0.8;
    transition: 0.3s;
  }
</style>
