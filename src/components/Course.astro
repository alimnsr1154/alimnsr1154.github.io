---
interface Props {
  icon: string;
  university: string;
  name: string;
  link: string;
  class?: string;
}
const { icon, name, university, link, class: className = '' } = Astro.props;
---

<div class={`container ${className}`}>
  <img src={icon} alt="" />
  <div class="details">
    <h4 class="title">{name}</h4>
    <p class="uni-name">{university}</p>
    <a target="_blank" href={link}>View certificate</a>
  </div>
</div>

<style>
  .container {
    display: flex;
    justify-content: start;
    padding: 8px;
    border-radius: 0.8rem;
    color: var(--color);
    width: 100%;
    backdrop-filter: blur(12px) saturate(150%);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .container::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    transition: left 0.6s ease;
    pointer-events: none;
  }

  .container:hover::before {
    left: 100%;
  }

  .container:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2), 0 0 20px rgba(var(--accent), 0.1);
    border-color: rgba(var(--accent), 0.2);
  }

  .container > img {
    width: 60px;
    height: 60px;
    border-radius: 0.8rem;
  }

  .details {
    margin-inline-start: 0.6rem;
  }
  .title {
    margin: 0;
    font-size: large;
  }
  .uni-name {
    margin: 0;
  }

  a {
    border: none;
    background-color: transparent;
    color: var(--primary);
    font-size: medium;
    padding-inline-start: 0;
    text-decoration: none;
    margin-inline-end: 1rem;
    transition: all 0.3s ease;
  }

  a:hover {
    opacity: 0.8;
    transform: translateX(4px);
  }

  .container.animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
  }

  .container.animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
