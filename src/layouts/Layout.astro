---
import PalestineBanner from "../components/PalestineBanner.astro";
import GithubIcon from "../icons/github.astro";
import LinkedinIcon from "../icons/linkedin.astro";
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/icon.png" />
    <meta name="theme-color" content="#3451b2" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Aref+Ruqaa+Ink:wght@700&display=swap"
      rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">

    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <title>
      Ali Mansoor - Mobile App Developer | Flutter Specialist | Full Stack Enthusiast
    </title>
    <meta
      name="description"
       content="Ali Mansoor is a passionate mobile app developer with 2+ years of experience building cross-platform applications using Flutter, Firebase, and modern backend technologies. He loves creating scalable, user-focused solutions."
    />
    <!-- Facebook Meta Tags -->
    <meta property="og:url" content="https://alimnsr1154.github.io/" />
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Ali Mansoor - Mobile App Developer | Flutter Specialist | Full Stack Enthusiast"
    />
    <meta
      property="og:description"
      content="Ali Mansoor is a passionate mobile app developer with 2+ years of experience building cross-platform applications using Flutter, Firebase, and modern backend technologies. He loves creating scalable, user-focused solutions."
    />
    <meta
      property="og:image"
      content="https://opengraph.b-cdn.net/production/documents/1070d3ed-cabc-4053-9639-8a11f02597a0.png?token=TdwZ_WLXT0j3DDJSGn8tHMSLEvpNDYAKl0ufnrvgY4c&height=285&width=584&expires=33247365255"
    />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="alimnsr1154.github.io" />
    <meta property="twitter:url" content="https://alimnsr1154.github.io/" />
    <meta
    name="twitter:title"
    content="Ali Mansoor - Mobile App Developer | Flutter Specialist | Full Stack Enthusiast"
    />
    <meta
      name="twitter:description"
      content="Ali Mansoor is a passionate mobile app developer with 2+ years of experience building cross-platform applications using Flutter, Firebase, and modern backend technologies. He loves creating scalable, user-focused solutions."
    />
    <meta
      name="twitter:image"
      content="https://opengraph.b-cdn.net/production/documents/1070d3ed-cabc-4053-9639-8a11f02597a0.png?token=TdwZ_WLXT0j3DDJSGn8tHMSLEvpNDYAKl0ufnrvgY4c&height=285&width=584&expires=33247365255"
    />

    <!-- Meta Tags Generated via https://www.opengraph.xyz -->
  </head>
  <body>
    <PalestineBanner />
    <nav>
      <div>
        <a href="/">
          <h2>على منصور</h2>
        </a>
      </div>
      <div class="links">
        <p>
          <a href="/about">About</a>
        </p>
        <p>
          <a href="/experience">Experience</a>
        </p>
        <p>
          <a href="/projects">Projects</a>
        </p>
        <p>
          <a href="/education">Education</a>
        </p>
      </div>
    </nav>

    <div class="twrapper" >
      <div class="social">
        <div class="icon">
          <a href="https://github.com/alimnsr1154" target="_blank">
            <GithubIcon /> 
          </a>
        </div>
        <div class="icon">
          <a href="https://www.linkedin.com/in/ali-mansoor-a1a06b248/" target="_blank">
            <LinkedinIcon />
          </a>
        </div>
        <div class="vertical-line"></div>
      </div>

      <section class="width: 100%;" >
        <slot />
      </section>

    </div>

    <script>
      // Animated cursor glow effect (desktop only)
      if (typeof window !== 'undefined' && window.innerWidth > 768) {
        document.addEventListener('mousemove', (e) => {
          document.documentElement.style.setProperty('--mx', e.clientX + 'px');
          document.documentElement.style.setProperty('--my', e.clientY + 'px');
        });
      }

      // Scroll progress bar
      window.addEventListener('scroll', () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent = docHeight > 0 ? scrollTop / docHeight : 0;
        document.documentElement.style.setProperty('--scroll-percent', scrollPercent);
      });

      // Create scroll progress element
      if (typeof window !== 'undefined') {
        const progressBar = document.createElement('div');
        progressBar.className = 'scroll-progress';
        document.body.insertBefore(progressBar, document.body.firstChild);

        window.addEventListener('scroll', () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          const scrollPercent = docHeight > 0 ? scrollTop / docHeight : 0;
          progressBar.style.width = (scrollPercent * 100) + '%';
        });
      }

      // IntersectionObserver for scroll-triggered animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1 }
      );

      // Observe all animate-on-scroll elements
      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });

      // Also handle dynamically added elements
      const mutationObserver = new MutationObserver(() => {
        document.querySelectorAll('.animate-on-scroll:not(.visible)').forEach((el) => {
          if (!el.hasAttribute('data-observed')) {
            el.setAttribute('data-observed', 'true');
            observer.observe(el);
          }
        });
      });

      mutationObserver.observe(document.body, { subtree: true, childList: true });
    </script>

    <style is:global>
      :root {
  --accent: 124, 58, 237;
  --accent-gradient: linear-gradient(
    45deg,
    rgb(var(--accent)),
    #3e63dd 30%,
    white 60%
  );
  --color: #ffffff;
  --background: #000000;
  --primary: #3451b2;
  --text: #ffffff;
  --text-light: #d1d1d1;
  --light-bg: #1a1a1a;
  --mx: 50vw;
  --my: 50vh;
}


      @media (prefers-color-scheme: dark) {
        :root {
          --accent: 124, 58, 237;
          --accent-gradient: linear-gradient(
            45deg,
            rgb(var(--accent)),
            #3e63dd 30%,
            white 60%
          );
          --color: #ecedee;
          --background: #151718;
          --primary: #849dff;
          --text: #ecedee;
          --text-light: #9ba1a6;
          --light-bg: #202425;
        }
      }

      /* Aurora animated background */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: -2;
        background: radial-gradient(ellipse 80% 60% at 20% 20%, rgba(100, 60, 237, 0.08), transparent),
                    radial-gradient(ellipse 60% 80% at 80% 80%, rgba(62, 99, 221, 0.06), transparent);
        animation: auroraShift 8s ease-in-out infinite alternate;
        pointer-events: none;
      }

      /* Animated cursor glow - desktop only */
      @media (min-width: 769px) {
        body::after {
          content: '';
          position: fixed;
          width: 500px;
          height: 500px;
          background: radial-gradient(circle, rgba(124, 58, 237, 0.06), transparent 70%);
          transform: translate(calc(var(--mx) - 250px), calc(var(--my) - 250px));
          pointer-events: none;
          z-index: -1;
          transition: transform 0.15s ease;
        }
      }

      /* Scroll progress bar */
      .scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        background: linear-gradient(90deg, #7c3aed, #3e63dd, #ecf0f1);
        width: 0%;
        z-index: 999;
        pointer-events: none;
        transition: width 0.1s ease;
      }

      html {
        font-family: "Open Sans", sans;
        background-color: var(--background);
        margin: 0;
        padding: 0;
      }
      body {
        margin: 0;
        padding: 0;
        animation: pageFadeIn 0.6s ease;
      }

      main {
        margin: auto;
        padding: 4rem 1.5rem 0 1.5rem;
        max-width: 110ch;
      }

      code {
        font-family: Menlo, Monaco, Lucida Console, Liberation Mono,
          DejaVu Sans Mono, Bitstream Vera Sans Mono, Courier New, monospace;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.4rem 0.8rem;
        animation: slideDown 0.8s ease-out;
        backdrop-filter: blur(20px) saturate(180%);
        background: rgba(0, 0, 0, 0.4);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      .twrapper {
        display: flex; 
        width: 90%;
        margin: 0 auto;
      }
      @media (min-width: 860px) {
.twrapper {
        width: 70%;
      }

      }
      @media (min-width: 1590px) {
        main {
          max-width: 140ch;
        }
      }

      @media (max-width: 450px) {
        nav {
          flex-direction: column;
        }
        h2 {
          display: none;
        }
        .links {
          margin-top: 0.4rem;
          font-size: small;
        }
      }
      nav h2 {
        margin: 0;
        font-family: "Aref Ruqaa Ink", serif;
        user-select: none;
      }
      .links {
        display: flex;
        gap: 0.8rem;
        display: flex;
          gap: 1.4rem;
      }

      .links a {
        text-decoration: none;
        color: var(--primary);
      }
      .social {
        position: fixed;
        bottom: 0;
        left: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .social .icon {
        color: var(--color);
      }
      .vertical-line {
        width: 1px;
        height: 100px;
        background-color: var(--color);
      }
      a {
        text-decoration: none;
      }

      @media (max-width: 1200px) {
        .social {
          display: none;
        }
      }

      ::selection {
        background-color: #3e63dd;
        color: white;
      }

      /* Custom Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb {
  background: #918d8d;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: #555;
}

      @keyframes slideDown {
        from {
          transform: translateY(-100%);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      @keyframes auroraShift {
        0% { transform: scale(1) rotate(0deg); }
        100% { transform: scale(1.05) rotate(3deg); }
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @keyframes slideLeft {
        from {
          opacity: 0;
          transform: translateX(-30px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }

      @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(5deg); }
      }

      @keyframes ringPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(var(--accent), 0.4); }
        50% { box-shadow: 0 0 0 12px rgba(var(--accent), 0); }
      }

      @keyframes pageFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @keyframes shimmer {
        0% { background-position: 200%; }
        100% { background-position: 0%; }
      }

      @keyframes typing {
        from { width: 0; }
        to { width: 100%; }
      }

      @keyframes blink {
        50% { border-right-color: transparent; }
      }

      @keyframes glowBorder {
        0% { background-position: 0%; }
        100% { background-position: 200%; }
      }

      /* Scroll-triggered animations */
      .animate-on-scroll {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }

      .animate-on-scroll.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Stagger delays for grouped animations */
      .animate-on-scroll:nth-child(1) { transition-delay: 0s; }
      .animate-on-scroll:nth-child(2) { transition-delay: 0.1s; }
      .animate-on-scroll:nth-child(3) { transition-delay: 0.2s; }
      .animate-on-scroll:nth-child(4) { transition-delay: 0.3s; }
      .animate-on-scroll:nth-child(5) { transition-delay: 0.4s; }
      .animate-on-scroll:nth-child(6) { transition-delay: 0.5s; }
    </style>
  </body>
</html>
