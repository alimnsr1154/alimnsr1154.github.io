---
import Layout from "../layouts/Layout.astro";
import Experience from "../components/ExperienceCard.astro";
---

<Layout title="Experience - Ali Mansoor">
  <main>
    <h2 class="animate-fade-in">Professional Experience</h2>
    <h2 class="animate-slide-up">Building scalable solutions across diverse projects and platforms</h2>
    <p class="animate-slide-up-delay">
      Throughout my career, I have thrived in collaborative, fast-paced environments where I contribute to building scalable, user-focused applications. I am committed to adaptability, teamwork, and clean code—principles that have enabled me to deliver impactful solutions across mobile and web platforms that drive real business value and exceptional user experiences.
    </p>

    <div class="experience-container">
      <Experience
        class="animate-on-scroll"
        title="Flutter Developer at Beyond One, Lahore"
        description="Currently developing and optimizing Flutter features for Virgin Connect Roam, an international eSIM roaming platform operating across multiple countries. Enhance UI/UX flows to accommodate diverse user demographics and languages, ensure seamless connectivity across international networks, and implement features that support global scalability. Contributed to building robust solutions handling complex cross-border digital services and international user requirements."
        subtitle="October 2025 – Present"
      />

      <Experience
        class="animate-on-scroll"
        title="Flutter Developer at Paymo, Lahore"
        description="Progressed across internship, part-time, and full-time roles at one of Pakistan's leading fintech platforms. Delivered mission-critical features including sophisticated QR code scanning systems for seamless payment transactions, real-time payment tracking providing instant transaction visibility, and secure money transfer infrastructure. Designed responsive UI components that improved app usability by 40%, architected scalable application structures that reduced payment processing time by 35%. Collaborated cross-functionally to ensure seamless integration across Android and iOS platforms serving millions of users."
        subtitle="July 2024 – September 2025"
        image="/images/paymo_logo.jpeg"
      />

      <Experience
        class="animate-on-scroll"
        title="Development Consultant at The Essential Studio, Islamabad (Remote)"
        description="Provided comprehensive software consultation and technical planning for 10+ client projects spanning diverse domains. Collaborated with cross-functional teams to deliver scalable product strategies and architected resilient software systems meeting complex client requirements. Streamlined remote development workflows, improving team productivity by 30%. Expanded perspective on diverse technology stacks, client management, and architectural decision-making at scale."
        subtitle="June 2024 – May 2025"
        image="/images/essential_studio.jpeg"
      />

      <Experience
        class="animate-on-scroll"
        title="Junior Flutter Developer at GRADE UP (Pvt.) Ltd, Islamabad"
        description="Began professional career as Junior Flutter Developer, transitioning from academic knowledge to practical software engineering. Enhanced mobile app functionality through hands-on feature development and performance optimization. Collaborated within agile teams to improve app versions, user experience, and code quality. Developed foundational expertise in Flutter, gained exposure to MERN stack technologies, strengthened problem-solving capabilities, and established best practices in clean code and scalable architecture that shaped my professional approach."
        subtitle="August 2023 – August 2024"
      />
    </div>
  </main>
</Layout>

<style>
  h2 {
    color: var(--color);
    margin-bottom: 1rem;
  }
  h2:first-child {
    font-size: 2.5rem;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  p {
    margin-bottom: 2rem;
    color: var(--color);
  }

  .experience-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    width: 100%;
  }

  .experience-container .animate-on-scroll:nth-child(1) { transition-delay: 0s; }
  .experience-container .animate-on-scroll:nth-child(2) { transition-delay: 0.1s; }
  .experience-container .animate-on-scroll:nth-child(3) { transition-delay: 0.2s; }
  .experience-container .animate-on-scroll:nth-child(4) { transition-delay: 0.3s; }

  .animate-fade-in {
    animation: fadeIn 1s ease-out;
  }

  .animate-slide-up {
    animation: slideUp 1s ease-out 0.2s both;
  }

  .animate-slide-up-delay {
    animation: slideUp 1s ease-out 0.4s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
